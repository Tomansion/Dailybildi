// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @default(cuid())
  username              String          @unique
  passwordHash          String
  createdAt             DateTime        @default(now())
  firstLoginAt          DateTime?
  receivedInitialBlocks Boolean         @default(false)
  
  inventory             UserInventory?
  worlds                World[]
  likes                 Like[]
}

model BlockCatalog {
  id                    String                @id @default(cuid())
  blockId               String
  layer                 Int
  rarity                Int
  universeId            String
  imagePath             String
  
  inventoryBlocks       InventoryBlock[]
  placedBlocks          PlacedBlock[]
  dailySelections       DailyBlockSelection[] @relation("SelectedBlocks")
  
  @@unique([blockId, universeId])
}

model DailyBlockSelection {
  id                    String         @id @default(cuid())
  date                  String         @unique
  createdAt             DateTime       @default(now())
  
  selectedBlocks        BlockCatalog[] @relation("SelectedBlocks")
}

model UserInventory {
  id                    String           @id @default(cuid())
  userId                String           @unique
  updatedAt             DateTime         @updatedAt
  
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks                InventoryBlock[]
}

model InventoryBlock {
  id                    String         @id @default(cuid())
  inventoryId           String
  blockCatalogId        String
  quantity              Int            @default(1)
  acquiredDate          DateTime       @default(now())
  
  inventory             UserInventory  @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  blockCatalog          BlockCatalog   @relation(fields: [blockCatalogId], references: [id])
  
  @@unique([inventoryId, blockCatalogId])
}

model World {
  id                    String         @id @default(cuid())
  userId                String
  universeId            String
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  likeCount             Int            @default(0)
  
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  placedBlocks          PlacedBlock[]
  likes                 Like[]
}

model PlacedBlock {
  id                    String       @id @default(cuid())
  worldId               String
  blockCatalogId        String
  gridX                 Int
  gridY                 Int
  rotation              Int          @default(0) // 0, 90, 180, 270
  flipX                 Boolean      @default(false)
  flipY                 Boolean      @default(false)
  zOrder                Int
  placedAt              DateTime     @default(now())
  
  world                 World        @relation(fields: [worldId], references: [id], onDelete: Cascade)
  blockCatalog          BlockCatalog @relation(fields: [blockCatalogId], references: [id])
}

model Like {
  id                    String   @id @default(cuid())
  userId                String
  worldId               String
  createdAt             DateTime @default(now())
  
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  world                 World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  
  @@unique([userId, worldId])
}
